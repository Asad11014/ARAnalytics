# ─── pf-forecaster environment ────────────────────────────────────────────────

# Postgres connection string.
# IMPORTANT: the demo deployment MUST point this at its OWN database — never the
# production DB. Demo data is seeded/cleared within a reserved ID range, but
# physical isolation is what guarantees the real DB can never be affected.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Mintsoft admin API key — enables the nightly incremental sync (cron).
# Leave unset on the demo deployment; the demo never calls Mintsoft.
MINTSOFT_ADMIN_KEY=

# ─── Demo mode ─────────────────────────────────────────────────────────────────
# Set to any truthy value ONLY on the public demo deployment. When enabled:
#   • the demo dataset is (re)seeded into DATABASE_URL on every boot
#   • POST /api/demo-login is exposed (no Mintsoft credentials required)
#   • live sync and the Mintsoft pass-through proxy are disabled
#   • all mutating requests are rejected (read-only demo)
# DEMO_MODE=true

# Server port (defaults to 3001)
# PORT=3001
